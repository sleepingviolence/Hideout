---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TOC from '../components/TOC.astro';



const { subtitle1,title,subtitle2, description, pubDate, updatedDate, heroImage,youtubeTrack,headings = []} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			
			.hero-image {
				 width: 100%;
				 display: flex;
                 justify-content: center;
				 max-width: 900px;
				 margin: 0 auto;
			}
			.hero-image img {
				width: 100%;                
                height: auto;
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}

			@media (max-width: 720px) {
  .hero-image img {
    width: 100%;
    height: auto;
    max-height: none;
    object-fit: unset;
    border-radius: 10px;
  }
}
			
			.title {
				margin-bottom:1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.3;
				white-space: pre-line;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

#player {
  position: fixed;
  right: 20px;
  bottom: 20px;
  z-index: 999;

   border-radius: 16px;
  overflow: hidden;

  box-shadow: 0 10px 30px rgba(0,0,0,0.3);

  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);

}

.floating-btn {
  position: fixed;
  right: 16px;
  bottom: 16px;

  width: 56px;
  height: 56px;

  border-radius: 50%;
  border: none;

  background: var(--accent);
  color: white;
  font-size: 18px;

  display: flex;
  align-items: center;
  justify-content: center;

  z-index: 1000;

  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

.floating-btn.playing::after {
  content: "";
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--accent);
  opacity: 0.5;
  animation: ripple 1.5s infinite;
}

@keyframes ripple {
  0% { transform: scale(1); opacity: 0.5; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* PCでは非表示 */
@media (min-width: 721px) {
  .floating-btn {
    display: none;
  }
}


		</style>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
	</head>

	

	<body>
		<Header />
		<main>
			
			    
				<div class="hero-image">
					    {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>

			    

				<div class="layout">

        <TOC headings={headings} />

                      
				<div class="content">
				    <div class="prose">
				
					  <div class="title">
						  <div class="date">
						    <FormattedDate date={pubDate} />
							{updatedDate && (
							  <div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							  </div>
							)}
						</div>
						
						{subtitle1 && <div class="subtitle">{subtitle1}</div>}  
						<h1 class="main">{title}</h1>
						{subtitle2 && <div class="subtitle">{subtitle2}</div>}
					</div>

          
						
					<hr />

					<slot />

				</div>
            </div>
					  
                
					
			</div>
			 
		  
		</main>
		<Footer />
{		
  youtubeTrack && (<div id="player">
  <div id="track"></div>
</div>
		)
}

{
  youtubeTrack && (
  <button id="miniPlayBtn" class="floating-btn">▶</button>
)}

</Footer>

<script is:inline>
window.addEventListener("DOMContentLoaded", () => {

  const toc = document.querySelector(".toc");

  if (!toc) return;

  // 初期状態
  if (window.innerWidth <= 720) {
    toc.removeAttribute("open");
  } else {
    toc.setAttribute("open", "");
  }

  // スマホだけタップ後閉じる
  toc.querySelectorAll("a").forEach((link) => {

    link.addEventListener("click", () => {

      if (window.innerWidth <= 720) {
        toc.removeAttribute("open");
      }

    });

  });

});
</script>

<script is:inline>
window.addEventListener("DOMContentLoaded", () => {

  const headings =
    document.querySelectorAll(
      ".prose h2, .prose h3, .prose h4"
    );

  const tocLinks =
    document.querySelectorAll(
      ".toc a"
    );
  
  

    

  const observer =
    new IntersectionObserver(
      (entries) => {

        entries.forEach((entry) => {

          if (!entry.isIntersecting) return;

          const id = entry.target.id;

          tocLinks.forEach((link) => {

            const href =
              link.getAttribute("href");

            if (href === `#${id}`) {
              link.classList.add("active");
            } else {
              link.classList.remove("active");
            }

          });

        });

      },
      {
        rootMargin: "-80px 0px -60% 0px"
      }
    );

  headings.forEach((h) => {
    observer.observe(h);
  });

});
</script>

 
<script define:vars={{ youtubeTrack }} is:inline>
if (!youtubeTrack) return;
let currentTrack = "";
let btn;



        function updateUI() 
        {
          if (!player || !btn) return;
          const state = player.getPlayerState();
          btn.classList.toggle("playing",state === YT.PlayerState.PLAYING);
        }
 

window.onYouTubeIframeAPIReady = () => {

  player = new YT.Player("track", {

    width: "300",

    height: "170",

    videoId: youtubeTrack,

    playerVars: {
      playsinline: 1,
	  controls: 0,
  modestbranding: 1,
  rel: 0
    },

    events: {
      onReady: (event) => {

        btn = document.getElementById("miniPlayBtn");

        updateUI();

        console.log("player ready");

        event.target.unMute();

        event.target.setVolume(50);

        btn?.addEventListener("click", () => 
        {
          const state = player.getPlayerState();
          
          if (state === YT.PlayerState.PLAYING) {player.pauseVideo();} 
          
          else {player.playVideo();}

          updateUI();
        });

  

		const sections =document.querySelectorAll("section[data-track]");

const observer = new IntersectionObserver(

    (entries) => {

      entries.forEach((entry) => {

        if (!entry.isIntersecting)
          return;

          const trackId = entry.target.dataset.track;

        const start =
  entry.target.dataset.start
    ? Number(entry.target.dataset.start)
    : 0;

    

       if (trackId === currentTrack)
  return;

currentTrack = trackId;

fadeToTrack(trackId,start);

      });

    }, {
      threshold: 0.6
    });

sections.forEach((section) => {
  observer.observe(section);
});
}
    }, onStateChange: () => { updateUI(); }
  });

};

const tag = document.createElement("script");

tag.src =
  "https://www.youtube.com/iframe_api";

document.body.appendChild(tag);
function fadeToTrack(trackId,startSeconds) {

  let volume =
    player.getVolume();

  const fadeOut =
    setInterval(() => {

      volume -= 10;

      player.setVolume(
        volume
      );

      if (volume <= 0) {

        clearInterval(
          fadeOut
        );

        player.loadVideoById({
          videoId: trackId,
  startSeconds: startSeconds
	  });

        fadeIn();

      }

    }, 80);

}


function fadeIn() {

  let volume = 0;

  player.setVolume(0);

  const fadeIn =
    setInterval(() => {

      volume += 10;

      player.setVolume(
        volume
      );

      if (volume >= 50) {

        clearInterval(
          fadeIn
        );

      }

    }, 80);

}
</script>
	</body>
</html>
