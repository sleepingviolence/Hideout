---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2>
      <a href="/" class="site-title">
      <span class="pc-title">{SITE_TITLE}</span>
      <span class="mobile-title">-102</span>
      </a>
    </h2>
		<div class="internal-links">
			<HeaderLink href="/">ロビー</HeaderLink>
			<HeaderLink href="/blog">備忘録</HeaderLink>
			
		</div>
		<div class="social-links">
			
			<a href="https://twitter.com/c4n_n0t_4nswer" target="_blank">
				<span class="sr-only">Follow Astro on Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			
		</div>

		<button id="themeToggle" class="theme-btn"aria-label="theme toggle">
  🌙
</button>
	</nav>
</header>
<style>
.mobile-title {
  display: none;
}

@media (max-width: 720px) {

  .pc-title {
    display: none;
  }

  .mobile-title {
    display: inline;
  }

}

	header {
position: sticky;
  top: 0;
  z-index: 1000;

		margin: 0;
    min-height: var(--header-height);
		padding: 0 1em;
		
		box-shadow: 0 2px 8px rgba(var(--black), 5%);

		background: var(--header-bg);
  color: var(--header-text);
  transition: background 0.3s, color 0.3s;
	}
	
	h2 {
		margin: 0;
		font-size: 1em;
    flex-shrink: 1;
    min-width: 0;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;

		 flex-wrap: wrap;
         gap: 0.5rem;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}

	.internal-links {
  display: flex;
  gap: 0.5rem;
}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}

		nav {
    padding: 0.4rem 0;
    flex-wrap: nowrap;
  }

  .internal-links {
    font-size: 0.9rem;
    gap: 0.2rem;
  }

  nav a {
    padding: 0.5em 0.3em;
  }

  .theme-btn {
    padding: 0.25em 0.5em;
    font-size: 0.85rem;
  }

  .social-links {
    display: none;
  }
	}

	.theme-btn {
  background: transparent;
  color: var(--header-text);
  border: 1px solid var(--header-text);
  border-radius: 8px;
  padding: 0.3em 0.7em;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.theme-btn:hover {
  background: var(--header-text);
  color: var(--header-bg);
}

header.hide {
    transform: translateY(-100%);
  }
	
</style>
<script is:inline>
  const root = document.documentElement;
  let btn;

  function setTheme(theme) {
    root.dataset.theme = theme;
    localStorage.setItem("theme", theme);

    if (btn) {
      btn.textContent = theme === "dark" ? "昼" : "夜";
    }
  }

  function initTheme() {
    const saved = localStorage.getItem("theme");

    const initial =
      saved ??
      (window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light");

    setTheme(initial);
  }

  window.addEventListener("DOMContentLoaded", () => {
    btn = document.getElementById("themeToggle");

    btn?.addEventListener("click", () => {
      const next =
        root.dataset.theme === "dark" ? "light" : "dark";

      setTheme(next);
    });

    initTheme();
  });
</script>

<script is:inline>
  let lastY = window.scrollY;
  const header = document.querySelector("header");

  window.addEventListener("scroll", () => {

    if (window.innerWidth > 720) return;

    const currentY = window.scrollY;

    if (currentY > lastY && currentY > 80) {
      header?.classList.add("hide");
    } else {
      header?.classList.remove("hide");
    }

    lastY = currentY;
  });
</script>